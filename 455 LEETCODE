class Solution:
    def findContentChildren(self, g: List[int], s: List[int]) -> int:
        m = len(g)
        n = len(s)
        g.sort()
        s.sort()
        count = 0
        left, right = 0, 0
        while left<m and right<n:
            if g[left]<=s[right]:
                count+=1
                left+=1
            right+=1
        return count
